#Connect to Mysql and analyze missing data rate per user
library(DBI)
library(RMariaDB)
library(ggplot2)

con <- dbConnect(
  MariaDB(),
  user     = "username",
  password = "password",
  dbname   = "DBname",
  unix.socket = "/opt/homebrew/var/mysql/mysql.sock"
)

query <-
  "SELECT user_id,
  MIN(record_date) AS first_date,
  DATE('yyyy-mm-dd') AS last_date,
  COUNT(record_date) AS actual_days
  FROM dbname
  GROUP BY user_id"

df <- dbGetQuery(con, query)

df$expected_days <- as.integer(df$last_date - df$first_date)+1
df$missing_days <- df$expected_days - df$actual_days
df$missing_rate <- df$missing_days /df$expected_days*100

ggplot(df, aes(x=missing_rate))+
  geom_histogram(bins=30)+
  labs(
    title ="MissingRate",
    x = "MIssing Rate(%)",
    y = "Users")

dbDisconnect(con)